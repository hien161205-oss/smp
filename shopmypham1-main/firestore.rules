rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Public read for storefront data
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /magazine/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Optional app config (hotline/banner...)
    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders/users are sensitive
    match /orders/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /users/{id} {
      allow read, write: if isAdmin();
    }

    // Block all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
